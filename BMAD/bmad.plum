@startuml
title BMAD Method Workflow — Стандартный Greenfield процесс

' =========================================================
' ФАЗА 1 — DISCOVERY (опциональная)
' =========================================================

start

:'Фаза 1 — Discovery (исследование)\nОпциональный этап для понимания проблемы,\nрынка и пользователей';

if ("Нужно ли проводить Discovery?") then (Да)

  :'Brainstorm\nГенерация идей и гипотез\n(участвуют аналитики и продуктовые роли)';

  :'Research\nИсследование пользователей,\nконкурентов и технологий';

  :'Product Brief\nКраткое описание продукта:\nцели, аудитория, ценность';

endif

' После discovery (или без него) создается PRD
:'PRD (Product Requirements Document)\nГлавный документ требований:\n- цели продукта\n- функциональность\n- ограничения\n- метрики успеха';

' =========================================================
' ФАЗА 2 — PLANNING
' =========================================================

:'Фаза 2 — Планирование\nНа основе PRD определяется структура продукта';

if ("Есть пользовательский интерфейс?") then (Да)

  :'Создание UX\nUX дизайнер определяет:\n- пользовательские потоки\n- интерфейсы\n- взаимодействия';

endif

' После UX или напрямую из PRD
:'Architecture\nАрхитектор определяет:\n- системную архитектуру\n- технологии\n- границы сервисов';

' =========================================================
' ФАЗА 3 — SOLUTIONING
' =========================================================

:'Фаза 3 — Проектирование решения\nПодготовка системы к реализации';

:'Validate Architecture\n(опционально)\nПроверка архитектуры\nна масштабируемость и риски';

:'Epics / Stories\nРазбиение продукта на\nэпики и пользовательские истории';

:'Test Design\n(опционально)\nПроектирование тестовой стратегии';

:'Implementation Readiness\nПроверка готовности\nк началу разработки';

' =========================================================
' ФАЗА 4 — IMPLEMENTATION
' =========================================================

:'Sprint Plan\nПланирование спринта:\nвыбор историй для реализации';

repeat

  :'Create Story\nСоздание конкретной\nuser story для реализации';

  :'Validate Story\n(опционально)\nПроверка полноты требований';

  :'Develop Story\nРазработка функции\nразработчиком или AI-агентом';

  :'Code Review\nПроверка кода\n(часто другим LLM или разработчиком)';

  if ("Code Review пройден?") then (Нет)

    :'Исправление замечаний\nи повторная разработка';

  else (Да)

    if ("Есть ещё истории\nв текущем эпике?") then (Да)

      ' продолжаем цикл историй
    else (Нет)

      :'Retrospective\nАнализ результатов спринта\nи улучшение процесса';

      if ("Есть ещё эпики?") then (Да)

        :'Планирование следующего спринта';

      else (Нет)

        stop

      endif

    endif

  endif

repeat while (Продолжаем разработку?)

@enduml
