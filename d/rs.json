      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "$datasource" },
          "editorMode": "code",
          "expr": "sum(increase(ruby_sidekiq_jobs_total{instance=~\"$instance\",queue=~\"$queue\",job_name=~\"$job_name\"}[$__range]))",
