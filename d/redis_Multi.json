      "targets": [{ "datasource": { "type": "prometheus", "uid": "$datasource" }, "editorMode": "code", "expr": "topk(10, sum by (instance, cmd) (rate(redis_commands_total{instance=~\"$instance\"}[$interval])))", "legendFormat": "{{instance}} {{cmd}}", "range": true, "refId": "A" }],
