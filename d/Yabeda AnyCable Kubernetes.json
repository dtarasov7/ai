          "editorMode": "code",
          "expr": "topk(15, sum by (method, command) (rate(anycable_rpc_call_count{job=~\"$job\",namespace=~\"$namespace\",service=~\"$service\",pod=~\"$pod\",method=~\"$method\",command=~\"$command\",status=~\"$status\"}[$interval])))",
