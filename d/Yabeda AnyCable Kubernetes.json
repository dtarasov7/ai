      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(anycable_rpc_call_runtime_seconds_bucket{job=~\"$job\",namespace=~\"$namespace\",service=~\"$service\",pod=~\"$pod\",method=~\"$method\",command=~\"$command\",status=~\"$status\"}[$__rate_interval])))",
          "legendFormat": "P95",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "P95 RPC runtime",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "ops"
