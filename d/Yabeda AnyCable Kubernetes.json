        {
          "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
          },
          "editorMode": "code",
          "expr": "sum by (method, command, status) (rate(anycable_rpc_call_count{job=~\"$job\",namespace=~\"$namespace\",service=~\"$service\",pod=~\"$pod\",method=~\"$method\",command=~\"$command\",status=~\"$status\"}[$__rate_interval]))",
          "legendFormat": "{{method}} {{command}} {{status}}",
          "range": true,
          "refId": "A"
        }
      ],
